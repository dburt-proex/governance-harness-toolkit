{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dburt-proex.github.io/governance-harness-toolkit/schemas/source-record.schema.json",
  "title": "Governed Source Record",
  "description": "Canonical evidence record for source authority, provenance, freshness, eligibility, and lifecycle control.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "title",
    "uri",
    "source_type",
    "authority_tier",
    "authority_role",
    "owner",
    "allowed_uses",
    "provenance",
    "freshness",
    "decision_eligibility",
    "lifecycle_status"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "pattern": "^SRC-[A-Z0-9][A-Z0-9._-]{2,63}$"
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "uri": { "type": "string", "format": "uri" },
    "source_type": {
      "enum": ["primary", "secondary", "internal", "contextual", "discovery"]
    },
    "authority_tier": { "type": "integer", "minimum": 1, "maximum": 4 },
    "authority_role": {
      "enum": ["authoritative", "corroborating", "contextual", "discovery_only"]
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "contact": { "type": "string", "maxLength": 240 }
      }
    },
    "allowed_uses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registered_by", "registered_at", "retrieved_at", "content_sha256"],
      "properties": {
        "registered_by": { "type": "string", "minLength": 1, "maxLength": 160 },
        "registered_at": { "type": "string", "format": "date-time" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "version_id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["window_days", "last_checked", "next_review", "status", "material_change"],
      "properties": {
        "window_days": { "type": "integer", "minimum": 1, "maximum": 3650 },
        "last_checked": { "type": "string", "format": "date" },
        "next_review": { "type": "string", "format": "date" },
        "status": {
          "enum": ["current", "due", "expired", "unknown", "review_required"]
        },
        "material_change": { "type": "boolean" },
        "change_summary": { "type": "string", "maxLength": 2000 }
      }
    },
    "decision_eligibility": {
      "enum": ["final", "corroboration_required", "context_only", "blocked"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "lifecycle_status": {
      "enum": ["proposed", "approved", "rejected", "retired", "unavailable"]
    },
    "notes": { "type": "string", "maxLength": 4000 }
  }
}
