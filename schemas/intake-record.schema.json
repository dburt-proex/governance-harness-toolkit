{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dburt-proex.github.io/governance-harness-toolkit/schemas/intake-record.schema.json",
  "title": "Governed Intake Record",
  "description": "Canonical request record for objective, scope, evidence, action authority, routing, and execution readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intake_id",
    "submitted_at",
    "requester",
    "objective",
    "domain",
    "priority",
    "risk_level",
    "requested_outputs",
    "success_criteria",
    "failure_conditions",
    "source_policy",
    "action_policy",
    "routing",
    "lifecycle_status"
  ],
  "properties": {
    "intake_id": {
      "type": "string",
      "pattern": "^INT-[A-Z0-9][A-Z0-9._-]{2,63}$"
    },
    "submitted_at": { "type": "string", "format": "date-time" },
    "requester": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "authority"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "authority": { "enum": ["owner", "delegate", "contributor", "external"] },
        "contact": { "type": "string", "maxLength": 240 }
      }
    },
    "objective": { "type": "string", "minLength": 10, "maxLength": 2000 },
    "domain": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "priority": { "enum": ["low", "normal", "high", "urgent"] },
    "risk_level": { "enum": ["low", "moderate", "high", "critical"] },
    "requested_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "format", "acceptance_criteria"],
        "properties": {
          "artifact_type": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
          "format": { "type": "string", "minLength": 1, "maxLength": 80 },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 3, "maxLength": 500 }
          }
        }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3, "maxLength": 500 }
    },
    "failure_conditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3, "maxLength": 500 }
    },
    "constraints": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3, "maxLength": 500 }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statement", "status"],
        "properties": {
          "statement": { "type": "string", "minLength": 3, "maxLength": 500 },
          "status": { "enum": ["unverified", "verified", "rejected"] }
        }
      }
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_classes", "citation_required", "freshness_required"],
      "properties": {
        "allowed_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["primary", "secondary", "internal", "contextual", "discovery"] }
        },
        "disallowed_sources": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "citation_required": { "type": "boolean" },
        "freshness_required": { "type": "boolean" }
      }
    },
    "action_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["external_writes", "approval_gate", "sensitive_data", "allowed_actions"],
      "properties": {
        "external_writes": { "enum": ["prohibited", "review_required", "authorized"] },
        "approval_gate": { "enum": ["none", "before_sensitive_action", "before_any_external_action"] },
        "sensitive_data": { "enum": ["none", "internal", "confidential", "restricted"] },
        "allowed_actions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "external_writes": { "const": "authorized" } }, "required": ["external_writes"] },
          "then": { "properties": { "approval_gate": { "not": { "const": "none" } } } }
        }
      ]
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow", "required_skills", "decision_state", "rationale"],
      "properties": {
        "workflow": {
          "enum": [
            "research_brief",
            "source_triage",
            "decision_memo",
            "system_spec",
            "evaluate_output",
            "package_publish",
            "recap_to_knowledge",
            "controlled_build",
            "manual_review"
          ]
        },
        "required_skills": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$" }
        },
        "decision_state": { "enum": ["ALLOW", "REVIEW", "HALT"] },
        "rationale": { "type": "string", "minLength": 10, "maxLength": 2000 }
      }
    },
    "lifecycle_status": {
      "enum": ["submitted", "triaged", "approved", "in_progress", "blocked", "completed", "cancelled"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "risk_level": { "enum": ["high", "critical"] } },
        "required": ["risk_level"]
      },
      "then": {
        "properties": {
          "routing": {
            "type": "object",
            "properties": { "decision_state": { "enum": ["REVIEW", "HALT"] } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "routing": {
            "type": "object",
            "properties": { "decision_state": { "const": "HALT" } },
            "required": ["decision_state"]
          }
        },
        "required": ["routing"]
      },
      "then": {
        "properties": { "lifecycle_status": { "enum": ["blocked", "cancelled"] } }
      }
    }
  ]
}
